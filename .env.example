# cc-useai-proxy local environment
# This file is gitignored — secrets only. process.env (Render dashboard) wins.

# Upstream OpenAI-compatible provider API key. REQUIRED or the upstream
# rejects requests. Get it from your provider (api.iamhc.cn / api.hcnsec.cn).
USEAI_API_KEY=REPLACE_WITH_YOUR_UPSTREAM_KEY

# Inbound auth gate. Leave EMPTY for a fully public site (everyone can use
# it). Set a value to require clients to send it as x-api-key / Authorization.
# The web chat UI sends x-api-key: broskillable, so to lock the UI down set
# PROXY_KEY=broskillable (or pick your own and update chat.html's key field).
PROXY_KEY=
